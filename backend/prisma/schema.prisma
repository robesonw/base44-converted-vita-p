generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id          String   @id @default(cuid()) @map("id")
  email       String   @unique @map("email")
  name        String?  @map("name")
  passwordHash String    @map("password_hash")
  role        Role     @default(USER) @map("role")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@map("users")
}

model FavoriteMeal {
  id                   String   @id @default(cuid()) @map("id")
  name                 String   @map("name")
  meal_type           String   @map("meal_type") 
  calories             String   @map("calories")
  protein              Float    @map("protein")
  carbs                Float    @map("carbs")
  fat                  Float    @map("fat")
  nutrients            String   @map("nutrients")
  prepTip              String   @map("prep_tips")
  prepTime             String   @map("prep_time")
  prepSteps            String[]  @map("prep_steps")
  difficulty           String   @map("difficulty")
  equipment            String[]  @map("equipment")
  healthBenefit        String   @map("health_benefit")
  imageUrl             String   @map("image_url")
  cuisine              String   @map("cuisine")
  cooking_time         String   @map("cooking_time")
  tags                 String[]  @map("tags")
  source_type          String   @map("source_type")
  source_meal_plan_id  String?  @map("source_meal_plan_id")
  source_meal_plan_name String? @map("source_meal_plan_name")
  source_recipe_id     String?  @map("source_recipe_id")
  ingredients          String[]  @map("ingredients")
  grocery_list         Json     @map("grocery_list")
  estimated_cost       Float?   @map("estimated_cost")
}

model Feedback {
  id            String   @id @default(cuid()) @map("id")
  user_name     String   @map("user_name")
  user_email    String   @map("user_email")
  page          String   @map("page")
  rating        Int      @map("rating")
  feedback_type String   @map("feedback_type")
  message       String   @map("message")
  status        String   @default("new") @map("status")
}

model ForumComment {
  id             String   @id @default(cuid()) @map("id")
  post_id        String   @map("post_id")
  content        String   @map("content")
  likes_count    Int      @default(0) @map("likes_count")
  author_name    String   @map("author_name")
  reactions       Json    @map("reactions")
}

model ForumPost {
  id             String   @id @default(cuid()) @map("id")
  title          String   @map("title")
  content        String   @map("content")
  category       String   @default("general") @map("category")
  tags           String[]  @map("tags")
  likes_count    Int      @default(0) @map("likes_count")
  views_count    Int      @default(0) @map("views_count")
  comments_count  Int      @default(0) @map("comments_count")
  is_pinned      Boolean   @default(false) @map("is_pinned")
  author_name    String   @map("author_name")
}

model GroceryList {
  id         String   @id @default(cuid()) @map("id")
  name       String   @map("name")
  items      Json     @map("items")
  total_cost Float     @map("total_cost")
  notes      String?   @map("notes")
}

model LabResult {
  id            String   @id @default(cuid()) @map("id")
  upload_date   DateTime @map("upload_date")
  file_url      String   @map("file_url")
  biomarkers     Json    @map("biomarkers")
  notes         String?   @map("notes")
}

model MealPlan {
  id         String   @id @default(cuid()) @map("id")
  name       String   @map("name")
  diet_type  String   @map("diet_type")
  cultural_style String @map("cultural_style")
  life_stage  String   @map("life_stage")
  days       Json     @map("days") // Nested object to hold daily plans
}

model Notification {
  id               String   @id @default(cuid()) @map("id")
  recipient_email  String   @map("recipient_email")
  type             String   @map("type")
  title            String   @map("title")
  message          String   @map("message")
  link             String?  @map("link")
  is_read          Boolean  @default(false) @map("is_read")
  actor_name       String   @map("actor_name")
}

model NutritionGoal {
  id                     String   @id @default(cuid()) @map("id")
  goal_type              String   @default("daily") @map("goal_type")
  target_calories        Float   @map("target_calories")
  target_protein         Float   @map("target_protein")
  target_carbs           Float   @map("target_carbs")
  target_fat             Float   @map("target_fat")
  target_micronutrients   Json @map("target_micronutrients")
  is_active              Boolean  @default(true) @map("is_active")
}

model NutritionLog {
  id             String   @id @default(cuid()) @map("id")
  recipe_name    String   @map("recipe_name")
  meal_type      String   @map("meal_type")
  log_date       DateTime @map("log_date")
  calories       Float     @map("calories")
  protein        Float     @map("protein")
  carbs          Float     @map("carbs")
  fat            Float     @map("fat")
  micronutrients  Json    @map("micronutrients")
  servings       Int      @default(1) @map("servings")
  food_source    String   @default("manual") @map("food_source")
  food_id        String?  @map("food_id")
}

model ProgressComment {
  id             String   @id @default(cuid()) @map("id")
  progress_id    String   @map("progress_id")
  comment        String   @map("comment")
  author_name    String   @map("author_name")
}

model RecipeComment {
  id             String   @id @default(cuid()) @map("id")
  recipe_id      String   @map("recipe_id")
  comment        String   @map("comment")
  author_name    String   @map("author_name")
}

model Review {
  id             String   @id @default(cuid()) @map("id")
  target_id      String   @map("target_id")
  target_type    String   @map("target_type")
  rating         Int      @map("rating")
  comment        String?   @map("comment")
  helpful_count   Int      @default(0) @map("helpful_count")
  author_name    String   @map("author_name")
}

model SharedMealPlan {
  id                     String   @id @default(cuid()) @map("id")
  original_plan_id       String   @map("original_plan_id")
  title                  String   @map("title")
  description            String   @map("description")
  plan_data              Json     @map("plan_data")
  diet_type              String   @map("diet_type")
  cultural_style         String   @map("cultural_style")
  tags                   String[]  @map("tags")
  views_count            Int      @default(0) @map("views_count")
  likes_count            Int      @default(0) @map("likes_count")
  saves_count            Int      @default(0) @map("saves_count")
  average_rating         Float?   @map("average_rating")
  author_name            String   @map("author_name")
}

model SharedProgress {
  id                     String   @id @default(cuid()) @map("id")
  title                  String   @map("title")
  description            String   @map("description")
  progress_type          String   @map("progress_type")
  stats                  Json     @map("stats")
  date_range             Json     @map("date_range")
  likes_count            Int      @default(0) @map("likes_count")
  comments_count         Int      @default(0) @map("comments_count")
  author_name            String   @map("author_name")
}

model SharedRecipe {
  id             String   @id @default(cuid()) @map("id")
  name           String   @map("name")
  meal_type      String   @map("meal_type")
  description     String   @map("description")
  meal_data      Json     @map("meal_data")
  calories       String   @map("calories")
  protein        Float     @map("protein")
  carbs          Float     @map("carbs")
  fat            Float     @map("fat")
  image_url      String   @map("image_url")
  tags           String[]  @map("tags")
  views_count    Int      @default(0) @map("views_count")
  likes_count    Int      @default(0) @map("likes_count")
  saves_count    Int      @default(0) @map("saves_count")
  average_rating Float?   @map("avg_rating")
  author_name    String   @map("author_name")
  status         String   @default("pending") @map("status")
  moderation_notes String? @map("moderation_notes")
  cuisine        String?  @map("cuisine")
  difficulty     String?  @map("difficulty")
  prep_time      String?  @map("prep_time")
  cooking_time   String?  @map("cooking_time")
  servings       Int?     @map("servings")
  ingredients    String[] @map("ingredients")
  prep_steps     String[] @map("prep_steps")
}

model UserFollow {
  id                     String   @id @default(cuid()) @map("id")
  following_user_email  String   @map("following_user_email")
  following_user_name   String   @map("following_user_name")
}

model UserInteraction {
  id               String   @id @default(cuid()) @map("id")
  target_id        String   @map("target_id")
  target_type      String   @map("target_type")
  interaction_type String   @map("interaction_type")
}

model UserPreferences {
  id                   String   @id @default(cuid()) @map("id")
  age                  Int?    @map("age")
  gender               String? @map("gender")
  height               Int?    @map("height")
  weight               Int?    @map("weight")
  health_goal         String?  @map("health_goal")
  dietary_restrictions String?  @map("dietary_restrictions")
  foods_liked         String?   @map("foods_liked")
  foods_avoided       String?    @map("foods_avoided")
  allergens            String[] @map("allergens")
  cuisine_preferences   String[] @map("cuisine_preferences")
  cooking_time        String?  @default("any") @map("cooking_time")
  skill_level         String?  @default("intermediate") @map("skill_level")
  num_people          Int?     @default(1) @map("num_people")
  weekly_budget       Float?   @default(100) @map("weekly_budget")
}

model UserSettings {
  id                               String   @id @default(cuid()) @map("id")
  email_notifications               Boolean  @default(true) @map("email_notifications")
  recipe_approved_notifications     Boolean  @default(true) @map("recipe_approved_notifications")
  recipe_rejected_notifications      Boolean  @default(true) @map("recipe_rejected_notifications")
  new_follower_notifications         Boolean  @default(true) @map("new_follower_notifications")
  comment_notifications              Boolean  @default(true) @map("comment_notifications")
  like_notifications                 Boolean  @default(false) @map("like_notifications")
  weekly_summary                     Boolean  @default(true) @map("weekly_summary")
}